BACKUP_ROOT=/opt/backup-platform
STATE_DIR=/var/lib/backup
LOG_DIR=/var/log/backup
TMP_DIR=/var/tmp/backup-platform
RESTIC_PASSWORD_FILE=/etc/backup/restic-password
RESTIC_RETENTION_DAILY=7
RESTIC_RETENTION_WEEKLY=4
RESTIC_RETENTION_MONTHLY=6
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_BACKUP_START=true
TELEGRAM_NOTIFY_BACKUP_SUCCESS=true
TELEGRAM_NOTIFY_BACKUP_FAILURE=true
TELEGRAM_NOTIFY_RESTORE_START=true
TELEGRAM_NOTIFY_RESTORE_SUCCESS=true
TELEGRAM_NOTIFY_RESTORE_FAILURE=true
TELEGRAM_NOTIFY_DISK_ALERT=true
TELEGRAM_NOTIFY_DISK_RECOVERY=false
TELEGRAM_NOTIFY_CPU_ALERT=true
TELEGRAM_NOTIFY_CPU_RECOVERY=false
TELEGRAM_NOTIFY_RAM_ALERT=true
TELEGRAM_NOTIFY_RAM_RECOVERY=false
TELEGRAM_NOTIFY_DOCKER_START=false
TELEGRAM_NOTIFY_DOCKER_STOP=true
TELEGRAM_NOTIFY_DOCKER_UNHEALTHY=true
TELEGRAM_NOTIFY_DOCKER_ERROR=true
TELEGRAM_NOTIFY_DOCKER_RECOVERY=false
TELEGRAM_NOTIFY_K8S_POD_START=false
TELEGRAM_NOTIFY_K8S_POD_ERROR=true
TELEGRAM_NOTIFY_K8S_POD_RECOVERY=false
TELEGRAM_NOTIFY_K8S_WORKLOAD_DEGRADED=true
TELEGRAM_NOTIFY_K8S_WORKLOAD_RECOVERY=false
SFTP_REPO_HOST=157.173.125.57
SFTP_REPO_PORT=22
SFTP_REPO_USER=root
SFTP_REPO_BASE=/srv/backups/orbix
SFTP_SSH_KEY=/root/.ssh/backup_sftp_157_ed25519
RESTIC_SFTP_COMMAND="ssh -i /root/.ssh/backup_sftp_157_ed25519 -p 22 -o StrictHostKeyChecking=yes -o BatchMode=yes root@157.173.125.57 -s sftp"
