SERVER_ID=vps-production
SOURCE_ROLE=generic-remote
SOURCE_MODE=ssh_pull
HOOK_SCRIPT=hooks/pre_remote_generic.sh
BACKUP_ENABLED=true
BACKUP_CRON="15 2 * * *"
DISK_CHECK_ENABLED=true
DISK_CHECK_CRON="*/30 * * * *"
DISK_THRESHOLD_PCT=85
DISK_ALERT_TARGETS="/ /var/lib/docker /var/www"
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=6
REMOTE_HOST=134.209.68.55
REMOTE_PORT=22
REMOTE_USER=root
REMOTE_SSH_KEY=/root/.ssh/backup_personaldigital_ed25519
REMOTE_PATHS="/etc/nginx /etc/mysql /home /opt /var/www"
REMOTE_PATHS_OPTIONAL="/etc/letsencrypt /root"
REMOTE_SYSTEM_EXPORT=true
REMOTE_DOCKER_EXPORT=true
REMOTE_DOCKER_VOLUMES="netdata-agent_netdata_cache netdata-agent_netdata_config netdata-agent_netdata_lib"
REMOTE_PRE_DUMP_COMMANDS=""
REMOTE_POSTGRES_DUMPS=""
REMOTE_MYSQL_DUMPS=""
REMOTE_MONGO_DUMPS=""
