SERVER_ID=vps-turnero-157
SOURCE_ROLE=generic-remote
SOURCE_MODE=ssh_pull
HOOK_SCRIPT=hooks/pre_remote_generic.sh
BACKUP_ENABLED=true
BACKUP_CRON="20 2 * * *"
DISK_CHECK_ENABLED=true
DISK_CHECK_CRON="*/30 * * * *"
DISK_THRESHOLD_PCT=85
DISK_ALERT_TARGETS="/ /var/lib/docker /home/services"
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=6
REMOTE_HOST=157.173.125.57
REMOTE_PORT=22
REMOTE_USER=root
REMOTE_SSH_KEY=/root/.ssh/backup_sftp_157_ed25519
REMOTE_PATHS="/etc/nginx /etc/mysql /home/services /home/turnero /home/prode /opt/turnero-psp-runtime"
REMOTE_PATHS_OPTIONAL="/etc/letsencrypt /root /var/www"
REMOTE_SYSTEM_EXPORT=true
REMOTE_DOCKER_EXPORT=true
REMOTE_DOCKER_VOLUMES="moodle_db_data moodle_moodle_data moodle_mysql_data turnero-psp-runtime_turnero_backend_uploads turnero_backend_uploads"
REMOTE_PRE_DUMP_COMMANDS=""
REMOTE_POSTGRES_DUMPS=""
